# Music Source Configuration
# Leave empty to disable a source

# Spotify API (get from https://developer.spotify.com/dashboard)
# Client ID and Secret for server authentication
SPOTIFY_CLIENT_ID= 133f8669605f41198c19b777c6648791
SPOTIFY_CLIENT_SECRET= 1f42dfee2ce947da87e050be2b321c5d

# YouTube is automatically disabled on production
# Only works locally with yt-dlp installed
NODE_ENV=development
PORT=3000

# Render deployment notes:
# - Set NODE_ENV=production in Render dashboard
# - Add SPOTIFY_CLIENT_ID and SPOTIFY_CLIENT_SECRET to Render environment variables
# - PORT is automatically assigned by Render (no need to set manually)
